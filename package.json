{
    "name": "vue3-ts-tpl",
    "author": "Perlou",
    "version": "1.0.0",
    "private": false,
    "type": "module",
    "description": "Vite + Vue3 + TypeScript + Element Plus template starter",
    "scripts": {
        "dev": "vite --mode development",
        "build": "vue-tsc --noEmit && vite build --mode production",
        "build:test": "vue-tsc --noEmit && vite build --mode test",
        "build:prod": "vue-tsc --noEmit && vite build --mode production",
        "preview": "vite preview",
        "format": "prettier --write ./src",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com:Perlou/vue3-ts-tpl.git"
    },
    "keywords": [
        "Vite",
        "Vue3",
        "TypeScript",
        "Element Plus",
        "Pinia"
    ],
    "bugs": {
        "url": "https://github.com/Perlou/vue3-ts-tpl/issues"
    },
    "homepage": "https://github.com/Perlou/vue3-ts-tpl#readme",
    "lint-staged": {
        "*.{vue,js,ts}": "eslint --fix",
        "*.{vue,js,ts,css,scss,md,json}": "prettier --write"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "dependencies": {
        "axios": "^1.7.9",
        "dayjs": "^1.11.13",
        "element-plus": "^2.9.1",
        "nprogress": "^0.2.0",
        "pinia": "^2.3.0",
        "vue": "^3.5.13",
        "vue-router": "^4.5.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@eslint/js": "^9.17.0",
        "@types/node": "^22.10.2",
        "@types/nprogress": "^0.2.3",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/test-utils": "^2.4.6",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.17.0",
        "eslint-plugin-vue": "^9.32.0",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "jsdom": "^25.0.1",
        "lint-staged": "^15.2.11",
        "prettier": "^3.4.2",
        "sass": "^1.82.0",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.18.1",
        "unplugin-auto-import": "^0.18.6",
        "unplugin-vue-components": "^0.27.5",
        "vite": "^6.0.5",
        "vitest": "^2.1.8",
        "vue-tsc": "^2.2.0"
    }
}
